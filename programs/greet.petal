# ─────────────────────────────────────────
# greet.petal
# Custom greeting function - from the spec
# ─────────────────────────────────────────

garden greet(tulip name) {
    bouquet b = new bouquet()
    b.add("rose",  "Hello, " + name + "!")
    b.add("lily",  name)
    b.add("daisy", "Welcome to the garden!")
    return b
}

# Call greet and bloom the result
bloom greet("Petalia")
bloom greet("Diego")
bloom greet("Reinaldo")
