# ─────────────────────────────────────────
# hello_world.petal
# Simple Hello World in Petalia
# ─────────────────────────────────────────

tulip msg = "Hello, World!"
bloom msg

# Bloom a bouquet greeting
bouquet greeting = new bouquet()
greeting.add("tulip", "Hello, World!")
greeting.add("rose", "Welcome to Petalia!")
greeting.add("daisy", "Where code blooms ")

bloom greeting
